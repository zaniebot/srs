{
  "schema_version": 1,
  "workloads": {
    "build": {
      "command": [
        "build",
        "--profile",
        "no-debug",
        "--bin",
        "uv",
        "--bin",
        "uvx",
        "--locked"
      ],
      "environment": {}
    },
    "clippy": {
      "command": [
        "clippy",
        "--workspace",
        "--all-targets",
        "--all-features",
        "--locked"
      ],
      "environment": {}
    },
    "test": {
      "command": [
        "nextest",
        "run",
        "--cargo-profile",
        "fast-build",
        "--features",
        "test-python-patch,native-auth,secret-service",
        "--workspace",
        "--profile",
        "ci-linux"
      ],
      "environment": {
        "INSTA_PENDING_DIR": "{run_directory}/pending-snapshots",
        "INSTA_UPDATE": "new",
        "RUST_BACKTRACE": "1",
        "UV_HTTP_RETRIES": "5",
        "UV_INTERNAL__TEST_ALT_FS": "/tmpfs",
        "UV_INTERNAL__TEST_COW_FS": "/btrfs",
        "UV_INTERNAL__TEST_LOWLINKS_FS": "/minix",
        "UV_INTERNAL__TEST_NOCOW_FS": "/tmpfs"
      }
    }
  }
}
